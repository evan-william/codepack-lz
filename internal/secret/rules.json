{
  "_comment": "Detection rules for codepack-lz secret scanning. Regex patterns adapted from the gitleaks default ruleset (github.com/gitleaks/gitleaks, MIT license) and simplified for RE2. keywords are lowercase substrings used as a cheap prefilter before running the regex. secret_group selects the capture group treated as the secret (0 = whole match). entropy, when > 0, is the minimum Shannon entropy (bits/char) the secret must have.",
  "allowlist": [
    "(?i)example|sample|placeholder|changeme|change_me|your[_-]|dummy|deadbeef|not[_-]?a[_-]?real|redacted",
    "\\$\\{[^}]*\\}",
    "\\{\\{[^}]*\\}\\}",
    "<[^>]{1,40}>",
    "%[sv]",
    "(?i)process\\.env|os\\.environ|getenv|\\bENV\\[",
    "(?i)x{6,}|\\*{4,}|0{8,}|1234567890"
  ],
  "rules": [
    {
      "id": "aws-access-key-id",
      "description": "AWS access key ID",
      "regex": "\\b((?:A3T[A-Z0-9]|AKIA|ASIA|ABIA|ACCA)[A-Z0-9]{16})\\b",
      "secret_group": 1,
      "keywords": ["akia", "asia", "a3t", "abia", "acca"]
    },
    {
      "id": "aws-secret-access-key",
      "description": "AWS secret access key near an aws keyword",
      "regex": "(?i)aws[a-z0-9_ .\\-]{0,30}[\"']?([0-9a-zA-Z/+]{40})[\"']?",
      "secret_group": 1,
      "entropy": 3.0,
      "keywords": ["aws"]
    },
    {
      "id": "github-pat",
      "description": "GitHub personal access token (classic)",
      "regex": "\\b(ghp_[A-Za-z0-9]{36})\\b",
      "secret_group": 1,
      "keywords": ["ghp_"]
    },
    {
      "id": "github-fine-grained-pat",
      "description": "GitHub fine-grained personal access token",
      "regex": "\\b(github_pat_[A-Za-z0-9]{22}_[A-Za-z0-9]{59})\\b",
      "secret_group": 1,
      "keywords": ["github_pat_"]
    },
    {
      "id": "github-oauth-token",
      "description": "GitHub OAuth access token",
      "regex": "\\b(gho_[A-Za-z0-9]{36})\\b",
      "secret_group": 1,
      "keywords": ["gho_"]
    },
    {
      "id": "github-app-token",
      "description": "GitHub app installation token",
      "regex": "\\b((?:ghu|ghs)_[A-Za-z0-9]{36})\\b",
      "secret_group": 1,
      "keywords": ["ghu_", "ghs_"]
    },
    {
      "id": "github-refresh-token",
      "description": "GitHub refresh token",
      "regex": "\\b(ghr_[A-Za-z0-9]{36,255})\\b",
      "secret_group": 1,
      "keywords": ["ghr_"]
    },
    {
      "id": "gitlab-pat",
      "description": "GitLab personal access token",
      "regex": "\\b(glpat-[A-Za-z0-9_\\-]{20,22})\\b",
      "secret_group": 1,
      "keywords": ["glpat-"]
    },
    {
      "id": "slack-token",
      "description": "Slack bot/user/app token",
      "regex": "\\b(xox[baprs]-[A-Za-z0-9\\-]{10,250})\\b",
      "secret_group": 1,
      "keywords": ["xoxb-", "xoxa-", "xoxp-", "xoxr-", "xoxs-"]
    },
    {
      "id": "slack-webhook-url",
      "description": "Slack incoming webhook URL",
      "regex": "(https://hooks\\.slack\\.com/(?:services|workflows)/[A-Za-z0-9+/_]{20,})",
      "secret_group": 1,
      "keywords": ["hooks.slack.com"]
    },
    {
      "id": "stripe-secret-key",
      "description": "Stripe live secret/restricted key",
      "regex": "\\b((?:sk|rk)_live_[A-Za-z0-9]{20,247})\\b",
      "secret_group": 1,
      "keywords": ["sk_live_", "rk_live_"]
    },
    {
      "id": "openai-api-key",
      "description": "OpenAI API key",
      "regex": "\\b(sk-(?:proj-|svcacct-|admin-)?[A-Za-z0-9_\\-]{20,74}T3BlbkFJ[A-Za-z0-9_\\-]{20,74})\\b",
      "secret_group": 1,
      "keywords": ["t3blbkfj"]
    },
    {
      "id": "anthropic-api-key",
      "description": "Anthropic API key",
      "regex": "\\b(sk-ant-[a-z0-9]{2,8}-[A-Za-z0-9_\\-]{80,120})\\b",
      "secret_group": 1,
      "keywords": ["sk-ant-"]
    },
    {
      "id": "google-api-key",
      "description": "Google API key",
      "regex": "\\b(AIza[0-9A-Za-z\\-_]{35})\\b",
      "secret_group": 1,
      "keywords": ["aiza"]
    },
    {
      "id": "gcp-service-account",
      "description": "Google Cloud service account credentials file",
      "regex": "(\"type\"\\s*:\\s*\"service_account\")",
      "secret_group": 1,
      "keywords": ["service_account"]
    },
    {
      "id": "npm-access-token",
      "description": "npm access token",
      "regex": "\\b(npm_[A-Za-z0-9]{36})\\b",
      "secret_group": 1,
      "keywords": ["npm_"]
    },
    {
      "id": "pypi-upload-token",
      "description": "PyPI upload token",
      "regex": "\\b(pypi-AgEIcHlwaS5vcmc[A-Za-z0-9_\\-]{50,})\\b",
      "secret_group": 1,
      "keywords": ["pypi-"]
    },
    {
      "id": "sendgrid-api-key",
      "description": "SendGrid API key",
      "regex": "\\b(SG\\.[A-Za-z0-9_\\-]{22}\\.[A-Za-z0-9_\\-]{43})\\b",
      "secret_group": 1,
      "keywords": ["sg."]
    },
    {
      "id": "twilio-api-key",
      "description": "Twilio API key (requires twilio context nearby)",
      "regex": "\\b(SK[0-9a-fA-F]{32})\\b",
      "secret_group": 1,
      "keywords": ["twilio"]
    },
    {
      "id": "digitalocean-pat",
      "description": "DigitalOcean personal access token",
      "regex": "\\b(dop_v1_[a-f0-9]{64})\\b",
      "secret_group": 1,
      "keywords": ["dop_v1_"]
    },
    {
      "id": "shopify-token",
      "description": "Shopify access token",
      "regex": "\\b(shp(?:at|ca|pa|ss)_[a-fA-F0-9]{32})\\b",
      "secret_group": 1,
      "keywords": ["shpat_", "shpca_", "shppa_", "shpss_"]
    },
    {
      "id": "telegram-bot-token",
      "description": "Telegram bot token (requires telegram context nearby)",
      "regex": "\\b([0-9]{8,10}:AA[A-Za-z0-9_\\-]{33})\\b",
      "secret_group": 1,
      "keywords": ["telegram"]
    },
    {
      "id": "heroku-api-key",
      "description": "Heroku API key near a heroku keyword",
      "regex": "(?i)heroku[a-z0-9_ .\\-]{0,40}\\b([0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12})\\b",
      "secret_group": 1,
      "keywords": ["heroku"]
    },
    {
      "id": "private-key",
      "description": "Private key block (PEM)",
      "regex": "(-----BEGIN[A-Z ]*PRIVATE KEY[A-Z ]*-----[\\s\\S]*?-----END[A-Z ]*PRIVATE KEY[A-Z ]*-----)",
      "secret_group": 1,
      "keywords": ["private key"]
    },
    {
      "id": "jwt",
      "description": "JSON Web Token",
      "regex": "\\b(ey[A-Za-z0-9_\\-]{17,}\\.ey[A-Za-z0-9_\\-]{17,}\\.[A-Za-z0-9_\\-]{10,})\\b",
      "secret_group": 1,
      "keywords": ["eyj"]
    },
    {
      "id": "database-url-password",
      "description": "Connection string with an inline password",
      "regex": "(?:postgres|postgresql|mysql|mariadb|mongodb|mongodb\\+srv|redis|rediss|amqp|amqps)://[^:/\\s\"']{1,64}:([^@/\\s\"']{3,256})@",
      "secret_group": 1,
      "entropy": 2.0,
      "keywords": ["postgres", "mysql", "mariadb", "mongodb", "redis", "amqp"]
    },
    {
      "id": "generic-api-key-quoted",
      "description": "Generic keyword-adjacent quoted secret with high entropy",
      "regex": "(?i)\\b(?:api[_\\-]?key|apikey|secret[_\\-]?key|client[_\\-]?secret|auth[_\\-]?token|access[_\\-]?token|secret|token|password|passwd|pwd)\\b[\"']?\\s*[:=]\\s*[\"']([A-Za-z0-9+/_\\-.=~]{16,120})[\"']",
      "secret_group": 1,
      "entropy": 3.5,
      "keywords": ["api", "secret", "token", "password", "passwd", "pwd", "auth"]
    },
    {
      "id": "generic-api-key-unquoted",
      "description": "Generic keyword-adjacent unquoted secret (env style) with high entropy",
      "regex": "(?im)^[ \\t]*(?:export[ \\t]+)?[A-Z0-9_]*(?:API_?KEY|SECRET|TOKEN|PASSWORD|PASSWD|PWD)[A-Z0-9_]*[ \\t]*=[ \\t]*([A-Za-z0-9+/_\\-.=~]{16,120})[ \\t]*$",
      "secret_group": 1,
      "entropy": 3.7,
      "keywords": ["api", "secret", "token", "password", "passwd", "pwd"]
    }
  ]
}
